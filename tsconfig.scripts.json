{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": false,
    "sourceMap": false,
    "incremental": false
  },
  "include": [
    "scripts/bootstrap-admin.ts",
    "lib/ory/bootstrap-client.ts"
  ]
}
